{
  "compilerOptions": {
    /* Module */
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,

    /* Linting */
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "types": [ "node" ],

    "rootDir": "src",
    "outDir": "dist"
  },
  "include": [ "src" ],
  "exclude": [ "node_modules" ]
}
